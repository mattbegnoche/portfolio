---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, tags, date, repoUrl, liveUrl } = project.data;
const { Content } = await render(project);
const formattedDate = date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
---

<BaseLayout title={title} description={description}>
  <a href="/projects" class="font-mono text-sm text-muted hover:text-ink">&larr; projects</a>

  <h1 class="mt-6 text-3xl font-medium">{title}</h1>

  <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2">
    <time class="font-mono text-xs text-muted">{formattedDate}</time>
    <ul class="flex flex-wrap gap-2 font-mono text-xs text-muted">
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <div class="flex gap-3 font-mono text-xs">
      {repoUrl && <a href={repoUrl} class="text-accent hover:underline">[Repo]</a>}
      {liveUrl && <a href={liveUrl} class="text-accent hover:underline">[Live]</a>}
    </div>
  </div>

  <div class="content-body mt-8">
    <Content />
  </div>
</BaseLayout>
