---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Changelog">
  <section id="hero" class="py-12 text-center">
    <span aria-hidden="true" class="text-2xl">🛠️</span>
    <h1 class="mt-3 text-3xl font-medium sm:text-4xl">
      Changelog <span class="text-ink/50">Information</span>
    </h1>
    <p class="mx-auto mt-3 max-w-lg text-ink/60">
      Stay updated on the latest improvements, enhancements, bug fixes, new features, design updates,
      and performance upgrades included in every release.
    </p>
  </section>

  <section class="mt-8">
    <div class="rounded-l bg-surface p-6">
      <p class="font-mono text-xs text-ink/50 uppercase">v1.0</p>
      <p class="mt-2 text-sm text-ink/70">
        Site rebuilt from scratch in Astro + Tailwind with a new design system — July 2026.
      </p>
    </div>
  </section>
</BaseLayout>
