---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found">
  <section id="hero" class="flex flex-col items-center gap-4 py-24 text-center">
    <span aria-hidden="true" class="text-2xl">🧭</span>
    <h1 class="text-3xl font-bold sm:text-4xl">
      Not found. <span class="text-ink/50">But you're on the right path</span>
    </h1>
    <a
      href="/"
      class="mt-4 inline-flex items-center gap-1.5 rounded-pill bg-accent px-5 py-3 text-sm font-bold text-white transition-colors duration-200 hover:bg-accent-dark"
    >
      Keep Exploring
    </a>
  </section>
</BaseLayout>
