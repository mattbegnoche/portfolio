---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const featuredProjects = (await getCollection("projects", ({ data }) => data.featured)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Home">
  <section>
    <p class="font-mono text-sm text-muted">/ hello</p>
    <h1 class="mt-3 text-3xl font-medium sm:text-4xl">Matthew Begnoche</h1>
    <p class="mt-4 max-w-xl text-muted">
      Software engineer building full-stack web apps and local-first tools. Currently a website
      developer at GoGuardian.
    </p>
  </section>

  <section class="mt-16">
    <p class="font-mono text-sm text-muted">/ featured projects</p>
    <div class="mt-6">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <a href="/projects" class="mt-6 inline-block font-mono text-sm text-accent hover:underline">
      [All projects]
    </a>
  </section>
</BaseLayout>
