---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const roles = [
  {
    title: "Website Developer",
    org: "GoGuardian",
    period: "Jun. 2024 – Present",
    bullets: ["Full-time"],
  },
  {
    title: "Website Developer",
    org: "One Branding",
    period: "Feb. 2022 – Present",
    bullets: ["Freelance"],
  },
  {
    title: "Logistics Officer",
    org: "Iowa National Guard",
    period: "Jun. 2022 – Present",
    bullets: ["Part-time"],
  },
];
---

<BaseLayout title="Home">
  <section>
    <p class="font-mono text-sm text-muted uppercase">/ hello</p>
    <h1 class="mt-3 text-3xl font-bold sm:text-4xl uppercase">Matthew Begnoche</h1>
    <p class="mt-4 max-w-xl text-muted">
      Software engineer building full-stack web apps and local-first tools. Currently a website
      developer at GoGuardian.
    </p>
  </section>

  <section id="projects" class="mt-16">
    <p class="font-mono text-sm text-muted uppercase">/ projects</p>
    <div class="mt-6">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="mt-16">
    <p class="font-mono text-sm text-muted uppercase">/ experience</p>
    <div class="mt-6">
      {
        roles.map((role) => (
          <div class="border-b border-hairline py-6 first:pt-0 last:border-none">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="text-base font-medium">
                {role.title} &mdash; {role.org}
              </h3>
              <p class="font-mono text-xs text-muted uppercase">{role.period}</p>
            </div>
            {role.bullets.length > 0 && (
              <ul class="mt-2 flex flex-col gap-1 text-sm text-muted">
                {role.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
