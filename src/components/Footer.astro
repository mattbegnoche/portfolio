---
import Card from "./Card.astro";

const year = new Date().getFullYear();

const menu = [
  { href: "/", label: "Home" },
  { href: "/works", label: "Works" },
  { href: "/about", label: "About" },
];

// TODO: swap in real profile URLs once you have them.
const follow = [
  { href: "#", label: "X (Twitter)" },
  { href: "#", label: "LinkedIn" },
];
---

<footer class="mx-auto w-full max-w-4xl px-6 pt-16 pb-32">
  <div class="flex flex-col items-center gap-6 text-center">
    <p class="font-mono text-xs text-ink/50 uppercase">Get in Touch</p>
    <h2 class="text-3xl font-bold sm:text-4xl">Let's Connect</h2>
    <a
      href="mailto:mattbegnochedev@gmail.com?subject=Hello!"
      class="inline-flex items-center gap-1.5 rounded-pill bg-accent px-6 py-3 text-sm font-bold text-white transition-colors duration-200 hover:bg-accent-dark"
    >
      Start Project
    </a>
  </div>

  <Card class="mt-8 flex flex-col items-center gap-2 p-10 text-center">
    <p class="font-mono text-xs text-ink/50 uppercase">Connect</p>
    <a
      href="mailto:mattbegnochedev@gmail.com?subject=Hello!"
      class="text-2xl font-bold wrap-break-word transition-colors duration-150 hover:text-accent"
    >
      mattbegnochedev@gmail.com
    </a>
  </Card>

  <Card class="mt-6 flex flex-col gap-12 p-10">
    <div class="flex flex-col gap-10 sm:flex-row sm:justify-between">
      <div class="flex flex-col gap-4">
        <div>
          <p class="text-lg font-bold">Hi, I'm Matt.</p>
          <p class="max-w-50 text-sm text-ink/60">
            I press buttons and interfaces happen
          </p>
        </div>
        <img
          src="/images/memoji/hero.avif"
          alt=""
          class="h-36 w-36 rounded-xl object-cover"
          loading="lazy"
        />
      </div>

      <div class="flex gap-16">
        <div>
          <p class="font-mono text-xs text-ink/50 uppercase">Menu</p>
          <ul class="mt-4 flex flex-col gap-2 text-lg font-bold">
            {
              menu.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="transition-colors duration-150 hover:text-accent"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <p class="font-mono text-xs text-ink/50 uppercase">Follow</p>
          <ul class="mt-4 flex flex-col gap-2 text-lg font-bold">
            {
              follow.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="transition-colors duration-150 hover:text-accent"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <div
      class="flex flex-col gap-2 font-mono text-xs text-ink/50 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {year}, Matt Begnoche Dev</p>
      <a href="#hero" class="transition-colors duration-150 hover:text-accent"
        >Back to Top</a
      >
    </div>
  </Card>
</footer>
