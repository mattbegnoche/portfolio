---
const links = [
  { href: "mailto:mattbegnochedev@gmail.com", label: "Email", newTab: false },
  { href: "https://github.com/mattbegnoche", label: "GitHub", newTab: true },
];
const year = new Date().getFullYear();
---

<footer class="border-t border-hairline">
  <div class="mx-auto flex max-w-3xl flex-col gap-4 px-6 py-10 font-mono text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {year} Matthew Begnoche</p>
    <ul class="flex gap-6">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              target={link.newTab ? "_blank" : undefined}
              rel={link.newTab ? "noopener noreferrer" : undefined}
              class="transition-colors duration-150 hover:text-ink"
            >
              [{link.label}]
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
