---
const year = new Date().getFullYear();

const menu = [
  { href: "/", label: "Home" },
  { href: "/works", label: "Works" },
  { href: "/about", label: "About" },
];

// TODO: swap in real profile URLs once you have them.
const follow = [
  { href: "#", label: "X (Twitter)" },
  { href: "#", label: "LinkedIn" },
];
---

<footer class="mx-auto w-full max-w-4xl px-6 pt-16 pb-32">
  <div class="flex flex-col items-start gap-6 rounded-xxl bg-surface p-10 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-mono text-xs text-ink/50 uppercase">Get in Touch</p>
      <p class="mt-2 text-2xl font-medium">Let's Connect</p>
    </div>
    <a
      href="mailto:mattbegnochedev@gmail.com?subject=Hello!"
      class="inline-flex items-center gap-1.5 rounded-pill bg-accent px-5 py-3 text-sm font-medium text-white transition-colors duration-200 hover:bg-accent-dark"
    >
      Start Project
    </a>
  </div>

  <div class="mt-12 flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
    <div class="flex items-center gap-3">
      <img
        src="/images/memoji/hero.avif"
        alt=""
        class="h-10 w-10 rounded-full object-cover"
        loading="lazy"
      />
      <p class="max-w-xs text-sm text-ink/60">Hi, I'm Matt. I press buttons and interfaces happen.</p>
    </div>

    <div class="flex gap-16">
      <div>
        <p class="font-mono text-xs text-ink/50 uppercase">Menu</p>
        <ul class="mt-3 flex flex-col gap-2 text-sm">
          {menu.map((item) => (
            <li>
              <a href={item.href} class="transition-colors duration-150 hover:text-accent">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="font-mono text-xs text-ink/50 uppercase">Follow</p>
        <ul class="mt-3 flex flex-col gap-2 text-sm">
          {follow.map((item) => (
            <li>
              <a href={item.href} class="transition-colors duration-150 hover:text-accent">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="mt-12 flex flex-col gap-2 border-t border-hairline pt-6 font-mono text-xs text-ink/50 sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {year}, Matt Begnoche Dev</p>
    <a href="#hero" class="transition-colors duration-150 hover:text-accent">Back to Top</a>
  </div>
</footer>
