---
import LocationIcon from "./icons/LocationIcon.astro";
import LocationTickIcon from "./icons/LocationTickIcon.astro";

const pinCount = 7;
const activePinIndex = 3;
---

<div class="grid grid-cols-1 gap-4 sm:grid-cols-6">
  <div class="flex flex-col justify-between gap-6 rounded-xxl bg-surface p-6 sm:col-span-3">
    <p class="text-lg font-medium">
      Full-stack developer with a love for clean UI and fast apps
    </p>
    <img
      src="/images/memoji/intro.avif"
      alt=""
      class="h-40 w-40 rounded-xl object-cover"
      loading="lazy"
    />
  </div>

  <div class="flex flex-col justify-between gap-6 rounded-xxl bg-surface p-6 sm:col-span-3">
    <p class="font-mono text-xs text-ink/50 uppercase">Based In</p>
    <p class="text-lg font-medium">Norwalk, Iowa</p>
    <div class="flex items-center justify-center gap-2">
      {
        Array.from({ length: pinCount }, (_, i) =>
          i === activePinIndex ? (
            <LocationTickIcon class="h-9 w-9 text-accent" />
          ) : (
            <LocationIcon class="h-6 w-6 text-ink/10" />
          ),
        )
      }
    </div>
  </div>

  <div class="flex flex-col gap-4 rounded-xxl bg-surface p-6 sm:col-span-3">
    <p class="font-mono text-xs text-ink/50 uppercase">Coding Since</p>
    <p class="text-lg font-medium">January 2022</p>
    <div class="rounded-xs border border-hairline bg-paper p-4">
      <div class="flex gap-1.5">
        <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-green"></span>
      </div>
      <pre class="mt-3 font-mono text-xs text-ink/60"><code>&lt;!DOCTYPE html&gt;
&lt;html lang="en"&gt;
  &lt;head&gt;...&lt;/head&gt;
&lt;/html&gt;</code></pre>
    </div>
  </div>

  <div class="flex flex-col justify-between gap-6 rounded-xxl bg-surface p-6 sm:col-span-3">
    <p class="font-mono text-xs text-ink/50 uppercase">What I Do</p>
    <p class="text-lg font-medium">Focused on fast builds, clean code, and smart design</p>
  </div>

  <div class="flex flex-col justify-between gap-6 rounded-xxl bg-surface p-6 sm:col-span-6">
    <p class="font-mono text-xs text-ink/50 uppercase">Always Learning</p>
    <div class="flex items-center justify-between gap-4">
      <p class="text-lg font-medium">Exploring Next.js &amp; TypeScript</p>
      <img
        src="/images/memoji/growth.avif"
        alt=""
        class="h-16 w-16 rounded-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</div>
