---
import Card from "./Card.astro";

interface Props {
  emoji: string;
  title: string;
  description: string;
}

const { emoji, title, description } = Astro.props;
---

<Card rounded="l" class="p-6">
  <span aria-hidden="true" class="text-2xl">{emoji}</span>
  <p class="mt-3 font-bold">{title}</p>
  <p class="mt-1 text-sm text-ink/60">{description}</p>
</Card>
