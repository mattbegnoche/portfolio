---
interface Props {
  emoji: string;
  title: string;
  description: string;
}

const { emoji, title, description } = Astro.props;
---

<div class="rounded-l bg-surface p-6">
  <span aria-hidden="true" class="text-2xl">{emoji}</span>
  <p class="mt-3 font-medium">{title}</p>
  <p class="mt-1 text-sm text-ink/60">{description}</p>
</div>
