---
import Card from "./Card.astro";

interface Props {
  title: string;
  org: string;
  employmentType: string;
  period: string;
  logo?: string;
}

const { title, org, employmentType, period, logo } = Astro.props;
---

<Card rounded="l" class="flex items-center gap-4 p-6">
  {
    logo ? (
      <img src={logo} alt="" class="h-10 w-10 shrink-0 rounded-xs object-contain" loading="lazy" />
    ) : (
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xs bg-black/5 dark:bg-white/10 font-mono text-xs text-ink/40">
        {org.charAt(0)}
      </div>
    )
  }
  <div class="flex flex-1 flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <div>
      <p class="font-bold">{title} &mdash; {org}</p>
      <p class="text-xs text-ink/50">{employmentType}</p>
    </div>
    <p class="font-mono text-xs text-ink/50 uppercase">{period}</p>
  </div>
</Card>
