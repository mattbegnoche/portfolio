---
const roundedClass = {
  xxxs: "rounded-xxxs",
  xxs: "rounded-xxs",
  xs: "rounded-xs",
  s: "rounded-s",
  m: "rounded-m",
  l: "rounded-l",
  xl: "rounded-xl",
  xxl: "rounded-xxl",
} as const;

type Radius = keyof typeof roundedClass;

interface Props {
  as?: "div" | "article" | "section";
  rounded?: Radius;
  class?: string;
}

const {
  as: Tag = "div",
  rounded = "xxl",
  class: className,
}: Props = Astro.props;
---

<Tag class:list={[roundedClass[rounded], "bg-surface", className]}>
  <slot />
</Tag>
