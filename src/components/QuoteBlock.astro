---
interface Props {
  quote: string;
  attribution: string;
  avatar?: string;
}

const { quote, attribution, avatar } = Astro.props;
---

<div class="rounded-s bg-surface p-6">
  <p class="font-mono text-xs text-ink/50 uppercase">Feedback</p>
  <p class="mt-3 text-lg font-medium">{quote}</p>
  <div class="mt-4 flex items-center gap-3">
    {
      avatar && (
        <img src={avatar} alt="" class="h-8 w-8 rounded-full object-cover" loading="lazy" />
      )
    }
    <p class="text-sm text-ink/60">{attribution}</p>
  </div>
</div>
