---
import Logo from "./Logo.astro";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
];
const currentPath = Astro.url.pathname;
---

<header class="border-b border-hairline">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-6">
    <a href="/" class="text-accent transition-opacity duration-150 hover:opacity-80">
      <Logo class="h-9 w-auto" />
    </a>
    <ul class="flex gap-6 font-mono text-sm">
      {
        navItems.map((item) => {
          const isActive =
            item.href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(item.href);
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  "transition-colors duration-150 hover:text-ink",
                  isActive ? "text-ink underline underline-offset-4" : "text-muted",
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
